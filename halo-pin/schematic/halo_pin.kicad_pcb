(kicad_pcb
  (version 20250101)
  (generator "hermes-agent")
  (general (thickness 1.6) (legacy_teardrops no))
  (paper "A4")
  (layers
    (0 "F.Cu" signal)
    (1 "In1.Cu" signal "GND")
    (2 "In2.Cu" signal "PWR")
    (31 "B.Cu" signal)
    (32 "B.Adhes" user "B.Adhesive")
    (33 "F.Adhes" user "F.Adhesive")
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user "User.Drawings")
    (41 "Cmts.User" user "User.Comments")
    (42 "Eco1.User" user "User.Eco1")
    (43 "Eco2.User" user "User.Eco2")
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user "B.Courtyard")
    (47 "F.CrtYd" user "F.Courtyard")
    (48 "B.Fab" user)
    (49 "F.Fab" user)
  )
  (setup
    (stackup
      (layer "F.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 1" (type "core") (thickness 0.2) (material "FR4"))
      (layer "In1.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 2" (type "prepreg") (thickness 0.7) (material "FR4"))
      (layer "In2.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 3" (type "core") (thickness 0.2) (material "FR4"))
      (layer "B.Cu" (type "copper") (thickness 0.035))
    )
    (pad_to_mask_clearance 0)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (usegerberextensions false)
      (usegerberattributes true)
      (usegerberadvancedattributes false)
      (creategerberjobfile true)
      (svgprecision 4)
      (excludeedgelayer true)
      (plotframeref false)
      (plotinvisibletext false)
      (padsonsilk false)
      (subtractmaskfromsilk false)
      (outputformat 1)
      (mirror false)
      (drillshape 0)
      (scaleselection 1)
      (outputdirectory "gerbers/")
    )
  )
  (net 0 "")
  (net 1 "VBUS")
  (net 2 "VBAT")
  (net 3 "+5V")
  (net 4 "+3V3D")
  (net 5 "+3V3A")
  (net 6 "VREF_3V0")
  (net 7 "GND")
  (net 8 "PD_OUT")
  (net 9 "LASER_DRIVE")
  (net 10 "LASER_MON")
  (net 11 "I2C1_SCL")
  (net 12 "I2C1_SDA")
  (net 13 "I2C3_SCL")
  (net 14 "I2C3_SDA")
  (net 15 "SPI2_SCK")
  (net 16 "SPI2_MISO")
  (net 17 "SPI2_MOSI")
  (net 18 "SPI2_CS")
  (net 19 "USART1_TX")
  (net 20 "USART1_RX")
  (net 21 "BLOWER_PWM")
  (net 22 "ENC_A")
  (net 23 "ENC_B")
  (net 24 "ADC_VBAT")

  ;; Board outline: 80 × 50 mm
  (gr_line (start 0 0) (end 80 0) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 80 0) (end 80 50) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 80 50) (end 0 50) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 0 50) (end 0 0) (layer "Edge.Cuts") (width 0.1))

  ;; ---- Footprints ----
  ;; STM32G474RET6 — LQFP-64 at (40, 25)
  (footprint "Package_QFP:LQFP-64_10x10mm_P0.5mm" (layer "F.Cu")
    (at 40 25)
    (property "Reference" "U1" (at 0 -8 0))
    (property "Value" "STM32G474RET6" (at 0 8 0))
  )

  ;; OPT101 — SO-8 at (10, 10)
  (footprint "Package_SO:SO-8" (layer "F.Cu")
    (at 10 10)
    (property "Reference" "U7" (at 0 -5 0))
    (property "Value" "OPT101" (at 0 5 0))
  )

  ;; ESP32-C3-MINI-1 at (65, 10)
  (footprint "RF_Module:ESP32-C3-MINI-1" (layer "F.Cu")
    (at 65 10)
    (property "Reference" "U11" (at 0 -8 0))
    (property "Value" "ESP32-C3-MINI-1" (at 0 8 0))
  )

  ;; SH1106 OLED at (65, 40)
  (footprint "Display:SH1106_128x64" (layer "F.Cu")
    (at 65 40)
    (property "Reference" "U12" (at 0 -10 0))
    (property "Value" "SH1106" (at 0 10 0))
  )

  ;; MicroSD at (10, 40)
  (footprint "Connector:MicroSD" (layer "F.Cu")
    (at 10 40)
    (property "Reference" "J2" (at 0 -8 0))
    (property "Value" "MicroSD" (at 0 8 0))
  )

  ;; USB-C at (5, 25)
  (footprint "Connector:USB_C_16pin" (layer "F.Cu")
    (at 5 25)
    (property "Reference" "J1" (at 0 -8 0))
    (property "Value" "USB-C" (at 0 8 0))
  )

  ;; 18650 holder at (40, 40)
  (footprint "Battery:Keystone_1042" (layer "F.Cu")
    (at 40 40)
    (property "Reference" "BT1" (at 0 -10 0))
    (property "Value" "18650" (at 0 10 0))
  )
)