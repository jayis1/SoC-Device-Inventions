  ; Transducer drivers — 72 BJT pairs (schematic shown as hierarchical)
  ; In production, use hierarchical sheet for repeated driver circuit
  ; Each: MMBT3904 + MMBT3906 + 1kΩ base resistor

  ; ---- Nets ----
  ; VCC_3V3, VCC_5V, VCC_10V, GND
  ; PIO_DATA, PIO_CLOCK, PIO_LATCH, PIO_BLANK
  ; UART_TX, UART_RX
  ; I2C0_SDA, I2C0_SCL (VL53L0X)
  ; I2C1_SDA, I2C1_SCL (OLED)
  ; SPI0_SCK, SPI0_MOSI, SPI0_MISO, SPI0_CS
  ; ADC_JOY_X, ADC_JOY_Y, ADC_VBAT
  ; ENC_A, ENC_B, ENC_BTN, BTN_MODE, BTN_RELEASE
  ; SAFETY_REED, TILT_IRQ
  ; TD[0..71] — transducer outputs

  ; ---- Hierarchical sheets ----
  (sheet (at 50 170) (size 250 30)
