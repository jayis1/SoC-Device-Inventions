# pico_sdk_import.cmake — boilerplate to import the Raspberry Pi Pico SDK
# Place a copy of this file from the pico-sdk repository here.
# Or set PICO_SDK_PATH environment variable to the SDK location.
#
# This is the standard import file distributed with the Pico SDK:
#   https://github.com/raspberrypi/pico-sdk
#
# Usage:
#   export PICO_SDK_PATH=/path/to/pico-sdk
#   mkdir build && cd build
#   cmake ..
#   make -j4