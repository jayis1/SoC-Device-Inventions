  ;; ==========================================
  ;; Notes
  ;; ==========================================
  (gr_text "Analog ground (VDD_A) is isolated from digital ground (VDD_D) via ferrite bead.\n"
           "Vmid reference (1.65V) biases both electrodes through 1MΩ resistors.\n"
           "INA333 gain set by 74HC4051 selecting Rg: 100k/10k/1k/100 Ω → G = 2/11/101/1001×.\n"
           "ADS1256 runs at 1 kSPS, PGA=64, single-ended on AIN0 (INA_OUT).\n"
           "DRDY → PA15 EXTI triggers SPI DMA read of 24-bit sample.\n"
           "Stimulus output is optocoupled (PC817), current-limited to 1 mA."
    (at 100 160)
  )

  (sheet_instances
    (path "/" (page "1/1"))
  )
