  ;; ============================================================
  ;; NET LABELS (key connections documented here)
  ;; ============================================================
  ;;
  ;; NET: VBUS     — USB-C 5V power
  ;; NET: VSYS     — LiPo battery (3.0–4.2V)
  ;; NET: 3V3      — AP2112K 3.3V regulated output
  ;; NET: GND      — Common ground
  ;; NET: I2C_SDA  — GPIO8, shared I2C bus
  ;; NET: I2C_SCL  — GPIO9, shared I2C bus
  ;; NET: I2S_BCLK — GPIO4, audio bit clock
  ;; NET: I2S_LRCK — GPIO5, audio LR clock
  ;; NET: I2S_DOUT — GPIO6, audio data
  ;; NET: SPI_TX   — GPIO16, flash MOSI
  ;; NET: SPI_RX   — GPIO17, flash MISO
  ;; NET: SPI_SCK  — GPIO18, flash clock
  ;; NET: SPI_CS   — GPIO19, flash CS
  ;; NET: MPR121_IRQ1 — GPIO14, keyboard touch interrupt
  ;; NET: MPR121_IRQ2 — GPIO15, func button interrupt
  ;; NET: OLED_DC  — GPIO20
  ;; NET: OLED_CS  — GPIO21
  ;; NET: OLED_RST — GPIO22
  ;; NET: ENC_A    — GPIO10
  ;; NET: ENC_B    — GPIO11
  ;; NET: ENC_SW   — GPIO12
  ;; NET: PWR_HOLD — GPIO13
  ;; NET: LED_BLUE — GPIO23
  ;; NET: LED_GRN  — GPIO25
  ;; NET: POT_MOD  — GPIO0 (ADC0)
  ;; NET: POT_ATK  — GPIO1 (ADC1)
  ;; NET: POT_REL  — GPIO2 (ADC2)
  ;; NET: POT_FB   — GPIO3 (ADC3)

)