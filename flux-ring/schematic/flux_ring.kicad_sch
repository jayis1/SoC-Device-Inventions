  ;; nRF52840-QIAA (QFN-48, 6x6mm)
  (symbol (lib_id "MCU_Nordic:nRF52840-QIAA") (at 127 76.2) (unit 1)
    (in_bom yes) (on_board yes)
    (uuid a5000000-0000-0000-0000-000000000001)
    (property "Reference" "U1" (at 127 30.48) (effects (font (size 1.27 1.27))))
