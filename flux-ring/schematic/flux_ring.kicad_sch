    (property "Footprint" "Package_DFN_QFN:Nordic_QFN-48-1EP_6x6mm_P0.4mm_EP4.6x4.6mm" (at 127 76.2) (effects (font (size 1.27 1.27)) hide))
    ;; Key connections:
    ;; P0.02 = I2C SDA (all sensors)
    ;; P0.03 = I2C SCL (all sensors)
    ;; P0.04 = ADC (battery voltage divider)
    ;; P0.05 = WS2812B data
    ;; P0.06 = DRV2603L EN
    ;; P0.07 = UART TX
    ;; P0.08 = UART RX
    ;; P0.09 = Touch input
    ;; P0.11 = MMC5983MA SET/RESET
    ;; P0.12 = OLED RESET
    ;; P0.13 = LIS2DH12 INT1
    ;; P0.14 = LIS2DH12 INT2 (WOM wake)
    ;; P0.15 = USB D+
    ;; P0.16 = USB D-
    ;; P0.17 = CHARGE_STAT LED
    ;; P0.18 = Mode LED
    ;; P0.19-22 = SPI (W25Q16)
    ;; P0.24 = Motor MOSFET
    ;; P0.25 = Motor current sense
    ;; P0.26 = Boot button
    ;; P0.27 = LDO EN
    ;; P0.28 = MMC5983MA INT
    ;; P0.29 = MS5837 CSB
    ;; P0.30 = DRV2603L addr select
    ;; P0.31 = Power LED
    ;; DEC1-4 = decoupling caps
    ;; VDD = 3.3V
    ;; GND = ground
    ;; XC1, XC2 = 32MHz crystal + 12pF caps
  )

