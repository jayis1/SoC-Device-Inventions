# Flux Ring — sdkconfig.defaults (nRF Connect SDK / Zephyr)
# Target: nRF52840

CONFIG_SOC_SERIES_NRF52X=y
CONFIG_SOC_NRF52840_QIAA=y
CONFIG_BOARD_NRF52840DK_NRF52840=y

# Clock
CONFIG_CLOCK_CONTROL_NRF=y
CONFIG_CLOCK_CONTROL_NRF_K32SRC_XTAL=y

# Bluetooth
CONFIG_BT=y
CONFIG_BT_PERIPHERAL=y
CONFIG_BT_DEVICE_NAME="Flux Ring"
CONFIG_BT_DEVICE_NAME_DYNAMIC=y
CONFIG_BT_MAX_CONN=1
CONFIG_BT_GATT_DYNAMIC=y

# BLE Long Range (optional)
CONFIG_BT_CTLR_ADV_EXT=y

# I2C
CONFIG_I2C=y
CONFIG_I2C_NRFX=y

# SPI (for flash logger)
CONFIG_SPI=y

# GPIO
CONFIG_GPIO=y

# ADC (battery voltage)
CONFIG_ADC=y

# Logging
CONFIG_LOG=y
CONFIG_LOG_DEFAULT_LEVEL=3
CONFIG_LOG_BACKEND_UART=y

# UART
CONFIG_UART_CONSOLE=y
CONFIG_SERIAL=y

# Power management
CONFIG_PM=y
CONFIG_PM_DEVICE=y

# Threading
CONFIG_MULTITHREADING=y
CONFIG_NUM_COOP_PRIORITIES=16
CONFIG_NUM_PREEMPT_PRIORITIES=16

# Stack sizes
CONFIG_MAIN_STACK_SIZE=2048
CONFIG_SYSTEM_WORKQUEUE_STACK_SIZE=1024

# Heap
CONFIG_HEAP_MEM_POOL_SIZE=1024

# Float/Double (needed for field calculations)
CONFIG_FPU=y
CONFIG_NEWLIB_LIBC=y
CONFIG_NEWLIB_LIBC_FLOAT_PRINTF=y