    (property "Value" "8MHz")
    (pin "1" (net "HSE_IN"))
    (pin "2" (net "HSE_OUT")))

  (symbol (lib_id "Device:Crystal") (at 78.74 152.4 0)
    (property "Reference" "Y2")
    (property "Value" "32.768kHz")
    (pin "1" (net "LSE_IN"))
    (pin "2" (net "LSE_OUT")))

  ;; ── LEDs ────────────────────────────────────────────────────────
  (symbol (lib_id "Device:LED") (at 106.68 152.4 0)
