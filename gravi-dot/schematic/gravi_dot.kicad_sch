    (pin "A" (net "LED_BLUE")))

  ;; ── Buttons + encoder ───────────────────────────────────────────
  (symbol (lib_id "Switch:SW_Push") (at 50.8 170.18 0)
    (property "Reference" "SW1") (property "Value" "STATION")
    (pin "1" (net "BTN_STATION")))

  (symbol (lib_id "Switch:SW_Push") (at 66.04 170.18 0)
    (property "Reference" "SW2") (property "Value" "BASE")
    (pin "1" (net "BTN_BASE")))

  (symbol (lib_id "Switch:SW_Push") (at 81.28 170.18 0)
    (property "Reference" "SW3") (property "Value" "MENU")
    (pin "1" (net "BTN_MENU")))

  (symbol (lib_id "Device:RotaryEncoder") (at 106.68 170.18 0)
