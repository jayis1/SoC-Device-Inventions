    (property "Value" "microSD")
    (pin "CS"   (net "SD_CS"))
    (pin "SCK"  (net "SPI2_SCK"))
    (pin "MISO" (net "SPI2_MISO"))
    (pin "MOSI" (net "SPI2_MOSI"))
    (pin "VDD"  (net "3V3"))
    (pin "GND"  (net "GND")))

  ;; ── Crystals ────────────────────────────────────────────────────
  (symbol (lib_id "Device:Crystal") (at 50.8 152.4 0)
