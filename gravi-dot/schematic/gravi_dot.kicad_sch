    (pin "A" (net "ENC_A"))
    (pin "B" (net "ENC_B")))

  ;; ── Power nets ──────────────────────────────────────────────────
  (net "3V3"  (type "power"))
  (net "5V0"  (type "power"))
  (net "VBAT" (type "power"))
  (net "VBUS" (type "power"))
  (net "GND"  (type "power"))
)