    (property "Value" "GREEN")
    (pin "A" (net "LED_GREEN")))

  (symbol (lib_id "Device:LED") (at 119.38 152.4 0)
    (property "Reference" "LED2")
    (property "Value" "RED")
    (pin "A" (net "LED_RED")))

  (symbol (lib_id "Device:LED") (at 132.08 152.4 0)
