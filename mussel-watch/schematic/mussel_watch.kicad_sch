  ;; ---- Connections (wire labels for net topology) ----
  ;; nRF52840 U1:
  ;;   P0.02 → ONEWIRE (DS18B20 1-Wire bus)
  ;;   P0.03 → I2C_SDA (TCA9548A, ADS1115, MS5837, Atlas DO, BME280)
  ;;   P0.04 → I2C_SCL
  ;;   P0.05 → BATTERY_V (SAADC, ÷2 divider)
  ;;   P0.06 → SOLAR_V (SAADC, ÷2 divider)
  ;;   P0.07 → SX1262_TCXO
  ;;   P0.08 → SENSOR_PWR (load switch to sensor head)
  ;;   P0.09 → MODE_BTN (tactile, active low with 10k pull-up)
  ;;   P0.10 → LED_BLUE
  ;;   P0.11 → LED_RED
  ;;   P0.12 → MUX_RESET (TCA9548A active-low reset)
  ;;   P0.15 → SD_PWR (load switch for SD card)
  ;;   P0.16 → DO_PWR (load switch for Atlas DO probe)
  ;;   P0.24 → SX1262_DIO1 (LoRa IRQ)
  ;;   P0.25 → SX1262_NRST (LoRa reset)
  ;;   P0.26 → SD_CS (SD card SPI CS)
  ;;   P0.28 → SPI_MISO (shared SX1262 + SD)
  ;;   P0.29 → SPI_MOSI
  ;;   P0.30 → SPI_SCK
  ;;   P0.31 → SX1262_CS (LoRa SPI CS)

  ;; SX1262 U2:
  ;;   NSS → SX1262_CS (P0.31)
  ;;   SCK → SPI_SCK (P0.30)
  ;;   MOSI → SPI_MOSI (P0.29)
  ;;   MISO → SPI_MISO (P0.28)
  ;;   DIO1 → SX1262_DIO1 (P0.24)
  ;;   NRST → SX1262_NRST (P0.25)
  ;;   TCXO → SX1262_TCXO (P0.07) + 3.3V TCXO enable
  ;;   ANT → 868/915 MHz antenna via SMA

  ;; TCA9548A U3:
  ;;   SDA/SCL → I2C_SDA/I2C_SCL (main bus from nRF)
  ;;   SD0-SD3 → separate I2C sub-buses to ADS1115 #0-#3 (4 mussel heads)
  ;;   RESET → MUX_RESET (P0.12)

  ;; ADS1115 U4 (Mussel A, address 0x48):
  ;;   SDA/SCL → MUX_SD0 (TCA9548A channel 0)
  ;;   AIN0 → HALL_OUT (DRV5053 output)
  ;;   ADDR → GND (0x48)

  ;; DRV5053 U5:
  ;;   OUT → HALL_OUT → ADS1115 AIN0
  ;;   VCC → VCC_3V3 (via SENSOR_PWR load switch)

  ;; DS18B20 U6:
  ;;   DQ → ONEWIRE (P0.02) with 4.7k pull-up to VCC_3V3
  ;;   VDD → VCC_3V3 (parasitic power mode optional; standard 3.3V mode)

  ;; MS5837 U7:
  ;;   SDA/SCL → I2C_SDA/I2C_SCL (main bus)
  ;;   VDD → VCC_3V3 (sensor head power)

  ;; BME280 U8:
  ;;   SDA/SCL → I2C_SDA/I2C_SCL (main bus)
  ;;   CSB → GND (I2C mode), SDO → GND (address 0x77)
  ;;   VDD → VCC_3V3 (always powered, in air pod)

  ;; Atlas DO EZO U9:
  ;;   SDA/SCL → I2C_SDA/I2C_SCL (main bus)
  ;;   PWR → DO_PWR (P0.16, load switch for power-gating)

  ;; MCP73871 U10:
  ;;   VIN → SOL1 (solar panel 6V via Schottky D1)
  ;;   BAT → BAT1 (LiPo 3.7V)
  ;;   VBUS → VBUS_5V (system power rail)
  ;;   STAT1 → LED charging indicator (optional)
  ;;   PROG → resistor sets charge current to ~500mA

  ;; ---- Decoupling capacitors ----
  ;; C1: 100nF on U1 VCC → GND
  ;; C2: 100nF on U2 VCC → GND
  ;; C3: 100nF on U3 VDD → GND
  ;; C4: 100nF on U4 VDD → GND
  ;; C5: 100nF on U7 VDD → GND
  ;; C6: 100nF on U8 VDD → GND
  ;; C7: 10uF bulk on VCC_3V3
  ;; C8: 4.7uF tantalum on LDO output

  ;; ---- Pull-up resistors ----
  ;; R1: 4.7k on I2C_SDA → VCC_3V3
  ;; R2: 4.7k on I2C_SCL → VCC_3V3
  ;; R3: 4.7k on ONEWIRE → VCC_3V3
  ;; R4: 4.7k on MUX_RESET → VCC_3V3 (active low)

  ;; ---- Voltage dividers for ADC ----
  ;; R5: 100k (VCC_3V3 → BATTERY_V) — actually from VBAT_3V7 through ÷2 to P0.05
  ;; R6: 100k (SOL1 → SOLAR_V) — ÷2 divider to P0.06
  ;; Each divider: top resistor 100k, bottom resistor 100k → ÷2

  ;; ---- LEDs ----
  ;; D2: Blue LED (P0.10) via 330Ω R7
  ;; D3: Red LED (P0.11) via 330Ω

  ;; ---- Mode button ----
  ;; SW1: Tactile (P0.09) to GND, 10k pull-up R8 to VCC_3V3

  (sheet_instances
    (path "/" (page "1"))
  )
)