  ;; ── Sheet 1: Main schematic (top level) ────────────────────────────
  ;; This is a simplified schematic representation; the full KiCad 7
  ;; project with hierarchical sheets and full symbol libraries would be
  ;; generated by KiCad. The net list below captures the essential
  ;; connections for review.

  ;; ─────────────────────────────────────────────────────────────────
  ;;  NET LIST (summary)
  ;; ─────────────────────────────────────────────────────────────────
  ;;
  ;;  U1  ESP32-S3-WROOM-1
  ;;    GPIO1  → SIPM1_DISC (RMT input, top SiPM discriminator)
  ;;    GPIO2  → SIPM2_DISC (RMT input, bottom SiPM discriminator)
  ;;    GPIO4  → ADS_SCK    (SPI clock to ADS7946)
  ;;    GPIO5  → ADS_CS     (SPI chip-select to ADS7946)
  ;;    GPIO6  → ADS_MISO   (SPI data from ADS7946)
  ;;    GPIO7  → ADS_MOSI   (SPI config to ADS7946)
  ;;    GPIO8  → ADC_TRIG   (CONVST to ADS7946, from coincidence logic)
  ;;    GPIO9  → I2C_SCL    (OLED + BMP390 + ICM-42688-P + MAX17048)
  ;;    GPIO10 → I2C_SDA
  ;;    GPIO11 → SD_SCK     (SPI2 to microSD)
  ;;    GPIO12 → SD_MISO
  ;;    GPIO13 → SD_MOSI
  ;;    GPIO14 → SD_CS
  ;;    GPIO15 → BIAS_EN    (SiPM 30V boost enable)
  ;;    GPIO16 → BIAS_MON   (ADC1_CH5, ÷30 divider)
  ;;    GPIO17 → VBAT_DIV   (ADC1_CH6, battery divider)
  ;;    GPIO18 → FAULT_LED  (red LED)
  ;;    GPIO19 → RUN_LED    (green LED)
  ;;    GPIO20 → MODE_BTN
  ;;    GPIO21 → START_BTN
  ;;    GPIO38 → BIAS_FAULT (TPS61158 OCP flag)
  ;;    GPIO39 → IMU_INT    (ICM-42688-P data-ready)
  ;;    GPIO40 → UART1_TX   (debug)
  ;;    GPIO41 → UART1_RX
  ;;    GPIO42 → BUZZER
  ;;    USB D-/D+ → USB-C
  ;;    EN, BOOT
  ;;
  ;;  U2  ADS7946  (SPI, 14-bit dual SAR ADC)
  ;;    SCLK ← GPIO4, CS# ← GPIO5, SDO → GPIO6, SDI ← GPIO7
  ;;    CONVST ← GPIO8
  ;;    CH0 ← TIA1_OUT (top SiPM peak-hold)
  ;;    CH1 ← TIA2_OUT (bottom SiPM peak-hold)
  ;;    REF ← REF5045 (+4.5V)
  ;;
  ;;  U3a U3b  SiPM 60035 (×2)
  ;;    Cathode → +30V (BIAS), Anode → TIA input
  ;;
  ;;  U5  OPA2356 (dual TIA)
  ;;    CH-A: SiPM1 anode → TIA → peak-hold → ADS CH0
  ;;    CH-B: SiPM2 anode → TIA → peak-hold → ADS CH1
  ;;
  ;;  U6  TLV3501 (×2, discriminators)
  ;;    U6a: TIA1_OUT → comparator → GPIO1 (SIPM1_DISC)
  ;;    U6b: TIA2_OUT → comparator → GPIO2 (SIPM2_DISC)
  ;;
  ;;  U8  BMP390 (I²C 0x77)
  ;;    SCL ← GPIO9, SDA ← GPIO10
  ;;
  ;;  U9  ICM-42688-P (I²C 0x69)
  ;;    SCL ← GPIO9, SDA ← GPIO10, INT → GPIO39
  ;;
  ;;  U10 TPS61158 (boost to +30V)
  ;;    EN ← GPIO15, FAULT → GPIO38, VOUT → SiPM cathodes + ÷30 → GPIO16
  ;;
  ;;  U11 AMS1117-3.3 (LDO)
  ;;    IN ← VBAT (4.2V), OUT → +3V3
  ;;
  ;;  U12 TP4056 (charger)
  ;;    IN ← USB-C 5V, BAT → LiPo, CHG/STDBY → status LEDs
  ;;
  ;;  U13 MAX17048 (fuel gauge, I²C 0x36)
  ;;    SCL ← GPIO9, SDA ← GPIO10
  ;;
  ;;  REF REF5045 → ADS7946 REF pin (+4.5V)
  ;;
  ;;  µSD  microSD (SPI2)
  ;;    SCK ← GPIO11, MISO → GPIO12, MOSI ← GPIO13, CS ← GPIO14
  ;;
  ;;  OLED SSD1306 (I²C 0x3C)
  ;;    SCL ← GPIO9, SDA ← GPIO10

