  ;; HX711 Load Cell
  (wire (pts (xy 20 7) (xy -30 7)))    ;; PA1 → HX711 DOUT
  (wire (pts (xy 20 9) (xy -30 9)))    ;; PA2 → HX711 PD_SCK
  (wire (pts (xy 20 11) (xy -30 11)))   ;; PB7 → HX711 power enable

  ;; IR Break-Beam
  (wire (pts (xy 20 13) (xy 30 13)))   ;; PB8 → IR LED out
  (wire (pts (xy 20 15) (xy 30 15)))   ;; PB9 → IR photo out
  (wire (pts (xy 20 17) (xy 30 17)))   ;; PB10 → IR LED in
  (wire (pts (xy 20 19) (xy 30 19)))   ;; PB11 → IR photo in

  ;; Power
  (wire (pts (xy 0 -25) (xy 0 -30)))   ;; VDD → 3.3V rail
  (wire (pts (xy 0 25) (xy 0 30)))     ;; VSS → GND

