    (symbol "CRYSTAL_32K"
      (in_bom yes)
      (on_board yes)
      (property "Reference" "CRY1" (at 0 5 0) (effects (font (size 1.27 1.27))))
      (property "Value" "32.768kHz" (at 0 0 0) (effects (font (size 1.27 1.27))))
      (property "Footprint" "Crystal:Crystal_SMD_3215-2Pin_3.2x1.5mm" (at 0 0 0))
      (symbol "CRYSTAL_32K_0_1"
        (rectangle (start -2 -3) (end 2 3)
          (stroke (width 0.254) (type default)) (fill (type none)))
        (pin bidirectional line (at -7 0 0) (length 5) (name "1") (number "1"))
        (pin bidirectional line (at 7 0 0) (length 5) (name "2") (number "2"))
      )
    )
    ; ---- Status LED ----
    (symbol "LED"
      (in_bom yes)
      (on_board yes)
      (property "Reference" "D1" (at 0 5 0) (effects (font (size 1.27 1.27))))
      (property "Value" "LED" (at 0 0 0) (effects (font (size 1.27 1.27))))
      (property "Footprint" "LED_SMD:LED_0805_2012Metric" (at 0 0 0))
      (symbol "LED_0_1"
        (polyline (pts (xy -2 1) (xy 2 1) (xy 0 -2) (xy -2 1))
          (stroke (width 0.254) (type default)) (fill (type none)))
        (pin power_in line (at 0 6 0) (length 5) (name "A") (number "1"))
        (pin power_in line (at 0 -6 0) (length 5) (name "K") (number "2"))
      )
    )
    ; ---- Tactile button ----
    (symbol "BUTTON"
      (in_bom yes)
      (on_board yes)
      (property "Reference" "S1" (at 0 5 0) (effects (font (size 1.27 1.27))))
      (property "Value" "6x6mm" (at 0 0 0) (effects (font (size 1.27 1.27))))
      (property "Footprint" "Button_Switch_SMD:SW_SPST_B3U-1000P" (at 0 0 0))
      (symbol "BUTTON_0_1"
        (circle (center 0 0) (radius 1)
          (stroke (width 0.254) (type default)) (fill (type none)))
        (pin bidirectional line (at -7 0 0) (length 6) (name "1") (number "1"))
        (pin bidirectional line (at 7 0 0) (length 6) (name "2") (number "2"))
      )
    )
  )
)