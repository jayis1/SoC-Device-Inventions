(kicad_pcb
  (version 20231129)
  (generator "thermo_trace")
  (general (thickness 1.6) (legacy_technology false))
  (paper "A4")
  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user "B.Adhesive")
    (33 "F.Adhes" user "F.Adhesive")
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user "User.Drawings")
    (41 "Cmts.User" user "User.Comments")
    (42 "Eco1.User" user "User.Eco1")
    (43 "Eco2.User" user "User.Eco2")
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user "B.Courtyard")
    (47 "F.CrtYd" user "F.Courtyard")
    (48 "B.Fab" user)
    (49 "F.Fab" user)
  )
  (setup
    (pad_to_mask_clearance 0.05)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disableapertmacros false)
      (usegerberextensions false)
      (usegerberattributes true)
      (usegerberadvancedattributes true)
      (creategerberjobfile true)
      (dashed_line_dash_ratio 12.000000)
      (dashed_line_gap_ratio 3.000000)
      (svgprecision 6)
      (plotframeref false)
      (viasonmask false)
      (mode 1)
      (useauxorigin false)
      (hpglpennumber 1)
      (hpglpenspeed 10)
      (hpglpendiameter 15.000000)
      (pdf_front_fp_property_popups true)
      (pdf_back_fp_property_popups true)
      (dxfpolygonmode true)
      (dxfimperialunits true)
      (dxfusepcbnewfont true)
      (psnegative false)
      (psa4output false)
      (plotreference true)
      (plotvalue true)
      (plotinvisibletext false)
      (sketchpadsonfab false)
      (subtractmaskfromsilk false)
      (outputformat 1)
      (mirror false)
      (drillshape 0)
      (scaleselection 1)
      (outputdirectory "gerbers/")
    )
  )
  (net 0 "")
  (net 1 "VCC")
  (net 2 "GND")
  (net 3 "VDD_3V3")
  (net 4 "VDD_5V")
  (net 5 "SPI1_SCK")
  (net 6 "SPI1_MISO")
  (net 7 "SPI1_MOSI")
  (net 8 "SPI2_SCK")
  (net 9 "SPI2_MISO")
  (net 10 "SPI2_MOSI")
  (net 11 "I2C1_SCL")
  (net 12 "I2C1_SDA")
  (net 13 "USART2_TX")
  (net 14 "USART2_RX")
  (net 15 "PWM_HEATER1")
  (net 16 "PWM_HEATER2")
  (net 17 "HEATER_EN")
  (net 18 "SAFETY_CMP")
  (net 19 "ADS_CS")
  (net 20 "ADS_START")
  (net 21 "ADS_DRDY")
  (net 22 "SD_CS")
  (net 23 "OLED_DC")
  (net 24 "OLED_RST")
  (net 25 "BTN_A")
  (net 26 "BTN_B")
  (net 27 "BTN_C")
  (net 28 "LED_RED")
  (net 29 "LED_GREEN")
  (net 30 "ESP_EN")
  (net 31 "DS18B20_DATA")
  (net 32 "BATT_V")
  (net 33 "PT1000_S")
  (net 34 "PT1000_R")
  (net 35 "HEATER1+")
  (net 36 "HEATER1-")
  (net 37 "HEATER2+")
  (net 38 "HEATER2-")
  (net 39 "CHRG_STAT")
  (net 40 "STDBY_STAT")

  (gr_text "THERMO TRACE - POCKET DSC" (at 55 30) (layer "F.SilkS"))
  (gr_text "(c) 2026 jayis1 - MIT" (at 55 33) (layer "F.SilkS"))

  /* Footprints placed roughly */
  (footprint "Package_QFP:LQFP-64_10x10mm_P0.5mm"
    (at 50 50)
    (layer "F.Cu")
    (property "Reference" "U1")
    (property "Value" "STM32G491RET6")
  )
  (footprint "Package_DFN_QFN:DFN-8_2x2mm_P0.5mm"
    (at 30 40)
    (layer "F.Cu")
    (property "Reference" "U2")
    (property "Value" "ADS122U04")
  )
  (footprint "RF_Module:ESP32-C3-MINI-1"
    (at 80 50)
    (layer "F.Cu")
    (property "Reference" "U3")
    (property "Value" "ESP32-C3-MINI-1")
  )
  (footprint "Display:SH1106_128x64"
    (at 50 20)
    (layer "F.Cu")
    (property "Reference" "U4")
    (property "Value" "SH1106_OLED")
  )
  (footprint "Package_TO_SOT_SMD:SOT-23-3"
    (at 35 65)
    (layer "F.Cu")
    (property "Reference" "U5")
    (property "Value" "TP4056")
  )
)