# volt-scribe sdkconfig
# STM32G491RET6 project configuration
# (CubeMX equivalent — key defines for HAL configuration)

# Clock configuration
CONFIG_CLOCK_HSE=8000000
CONFIG_CLOCK_SYSCLK=170000000
CONFIG_CLOCK_AHB=170000000
CONFIG_CLOCK_APB1=170000000
CONFIG_CLOCK_APB2=170000000

# Peripheral enables
CONFIG_DAC1_ENABLE=y
CONFIG_DAC2_ENABLE=y
CONFIG_ADC1_ENABLE=y
CONFIG_ADC2_ENABLE=y
CONFIG_I2C1_ENABLE=y
CONFIG_SPI1_ENABLE=y
CONFIG_UART1_ENABLE=y
CONFIG_TIM1_ENABLE=y
CONFIG_TIM6_ENABLE=y
CONFIG_TIM8_ENABLE=y
CONFIG_CORDIC_ENABLE=y
CONFIG_OPAMP1_ENABLE=y
CONFIG_COMP1_ENABLE=y

# UART configuration (to ESP32-C3)
CONFIG_UART1_BAUD=115200

# I2C configuration (OLED + ADS1115)
CONFIG_I2C1_SPEED=400000

# SPI configuration (SD card)
CONFIG_SPI1_SPEED=25000000

# DAC1 configuration (potentiostat setpoint)
CONFIG_DAC1_RESOLUTION=12
CONFIG_DAC1_REFERENCE=2.048

# ADC1 configuration (TIA current)
CONFIG_ADC1_RESOLUTION=12
CONFIG_ADC1_REFERENCE=3.3

# ADC2 configuration (WE potential)
CONFIG_ADC2_RESOLUTION=12
CONFIG_ADC2_REFERENCE=3.3

# ADS1115 configuration
CONFIG_ADS1115_ADDRESS=0x48
CONFIG_ADS1115_RANGE=PM4_096V

# SD card
CONFIG_SD_MOUNT_POINT=/sd
CONFIG_SD_MAX_FILES=5

# Display
CONFIG_OLED_WIDTH=128
CONFIG_OLED_HEIGHT=64
CONFIG_OLED_I2C_ADDR=0x3C

# BLE relay protocol version
CONFIG_BLE_PROTOCOL_VERSION=1

# Power management
CONFIG_BATTERY_LOW_THRESHOLD=3.3
CONFIG_USB_DETECT_PIN=PB14